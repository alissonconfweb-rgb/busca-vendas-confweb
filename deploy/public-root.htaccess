Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^api(/|$) - [L]
  RewriteRule ^_app(/|$) - [F,L]
  RewriteRule ^(server|src|docs|data|node_modules)(/|$) - [F,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

<FilesMatch "^(\.env|.*\.sqlite|package(-lock)?\.json|tsconfig.*|vite\.config\.ts|render\.yaml)$">
  Require all denied
</FilesMatch>
