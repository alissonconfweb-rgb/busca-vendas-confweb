# Copie este arquivo para .env em desenvolvimento local.
# Nunca suba .env real para o GitHub.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# URL publica do frontend/backend em producao.
# Exemplo: https://busca-vendas.seudominio.com.br
PUBLIC_URL=
FRONTEND_ORIGIN=

# Dono/criador do projeto. Este e-mail sempre recebe acesso admin.
# Se ficar vazio, o sistema usa ADMIN_EMAIL como criador.
CREATOR_EMAIL=seu-email@dominio.com

# Admin inicial. O servidor cria/atualiza este usuario ao iniciar.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@dominio.com
ADMIN_PASSWORD=troque-esta-senha

# Gere uma string longa e unica para assinar sessoes.
# Exemplo no Node: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque-por-uma-chave-longa
SESSION_TTL_DAYS=365

# Tempo maximo de resposta da busca.
SEARCH_RESPONSE_TIMEOUT_MS=85000

# Playwright/Chromium. Em hospedagens com filesystem restrito, manter 0 instala no projeto.
PLAYWRIGHT_BROWSERS_PATH=0

# Mercado Livre OAuth/API oficial. Opcional enquanto usar Oxylabs/fallback.
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=
MELI_SITE_ID=MLB
MELI_ACCESS_TOKEN=
MELI_REFRESH_TOKEN=
MELI_SCRAPER_ENABLED=true

# Oxylabs. Opcional, mas recomendado para leituras reais das paginas publicas.
OXYLABS_MODE=web_unblocker
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_ENDPOINT=https://unblock.oxylabs.io:60000
OXYLABS_GEO_LOCATION=Brazil
OXYLABS_TIMEOUT_MS=120000
OXYLABS_RENDER_WAIT_SECONDS=5
OXYLABS_PRODUCT_LIMIT=3
