{
  "name": "busca-vendas-confweb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node server/index.mjs\" \"vite --host 127.0.0.1\"",
    "dev:web": "vite --host 127.0.0.1",
    "api": "node server/index.mjs",
    "admin:create": "node server/create-admin.mjs",
    "build": "tsc && vite build",
    "start": "node server/index.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "playwright": "^1.61.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
